modules = ["python-3.11", "nodejs-20"]
[userenv]

[userenv.shared]
API_BASE = "https://api.openai.com/v1"
MODEL_NAME = "gpt-4o"
TEMPERATURE = "0.7"
MAX_TOKENS = "2000"
MONGODB_DATABASE = "manus"
REDIS_PORT = "6379"
REDIS_DB = "0"
SANDBOX_ADDRESS = "localhost"
SEARCH_PROVIDER = "bing"
AUTH_PROVIDER = "local"
LOCAL_AUTH_EMAIL = "admin@example.com"
LOCAL_AUTH_PASSWORD = "admin"
JWT_ALGORITHM = "HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES = "30"
JWT_REFRESH_TOKEN_EXPIRE_DAYS = "7"
LOG_LEVEL = "INFO"
BACKEND_URL = "http://localhost:8000"

[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["cargo", "gitFull", "libiconv", "libxcrypt", "openssl", "pkg-config", "playwright-driver", "rustc"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Sandbox Service"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Frontend"

[[workflows.workflow]]
name = "Sandbox Service"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/sandbox && python -m uvicorn app.main:app --host 0.0.0.0 --port 8080"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/backend && python -m uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Frontend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/frontend && npx vite --host 0.0.0.0 --port 5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8080
externalPort = 8080
